# ─────────────────────────────────────────────────────────────────────────────
# Vigilane — environment variables
#
# Copy this file to .env and fill in your values.
# All EXPO_PUBLIC_* vars are embedded in the JS bundle at build time and are
# safe to use client-side. Never put secrets (private keys, admin credentials)
# in EXPO_PUBLIC_* vars.
# ─────────────────────────────────────────────────────────────────────────────

# ── Firebase Web SDK config ──────────────────────────────────────────────────
# Values come from the Firebase Console → Project Settings → Your apps → Web app.
# These are the public client-side identifiers — NOT the service-account private key.

EXPO_PUBLIC_FIREBASE_API_KEY=your-web-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
EXPO_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxxxxxxxxxx

# ── Backend API ──────────────────────────────────────────────────────────────
# Base URL for the Flask API (src/main.py).
# Defaults: http://10.0.2.2:5000 (Android emulator) / http://127.0.0.1:5000 (iOS sim)
# Set this when pointing at a deployed server or a LAN IP.

# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.100:5000

# ── Python backend (Flask + Firebase Admin SDK) ───────────────────────────────
# These are ignored by Expo — only the Python process reads them.

# Path to the service-account JSON downloaded from Firebase Console →
# Project Settings → Service accounts → Generate new private key.
FIREBASE_KEY_PATH=serviceAccountKey.json

# Required at startup — generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here

# Comma-separated allowed CORS origins. Defaults to * if unset.
# CORS_ORIGINS=https://yourapp.com

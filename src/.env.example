# ─────────────────────────────────────────────────────────────────────────────
# HackSLU2026 backend — environment variables
#
# Copy this file to src/.env and fill in your values.
# Never commit the real .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Firebase Admin SDK ───────────────────────────────────────────────────────
# Path to the service-account JSON downloaded from Firebase Console →
# Project Settings → Service accounts → Generate new private key.
FIREBASE_KEY_PATH=path/to/serviceAccountKey.json

# ── Encryption ───────────────────────────────────────────────────────────────
# Required at startup — the app will refuse to start without this.
# Generate a key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.  Defaults to * (all) if unset.
# Example for production:
#   CORS_ORIGINS=https://yourapp.com,https://www.yourapp.com
# CORS_ORIGINS=*
